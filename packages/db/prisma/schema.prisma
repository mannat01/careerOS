// CareerOS — M01 core entities (database-schema.md). Prisma migrations are the
// schema source of truth; this file covers ONLY the M01 slice — later milestones
// add resume/application/prep/memory/CIE tables via expand/contract migrations.
//
// Migration `init_m01` has been applied against live Postgres (pgvector/pg16).
// The Prisma-backed stores in packages/db/src/stores/ use the generated client.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum SubscriptionTier {
  free
  pro
}

enum UserStatus {
  active
  suspended
  deleted
}

enum Provenance {
  imported
  user
  inferred_confirmed
}

enum SkillLevel {
  beginner
  intermediate
  advanced
  expert
}

enum SourceType {
  ats_public
  licensed_aggregator
  gov_feed
  user_oauth
}

enum AuditActor {
  user
  twin
  system
}

// database-schema.md §memory — MemoryEvent.type.
enum MemoryEventType {
  twin_action
  user_decision
  outcome
  system
}

// database-schema.md §application — the fixed pipeline, in order.
// saved → drafting → ready → applied → screening → interviewing → offer → closed.
// `closed` is reachable from any non-terminal state (drop / reject at any stage).
enum ApplicationStatus {
  saved
  drafting
  ready
  applied
  screening
  interviewing
  offer
  closed
}

// database-schema.md §briefing — BriefingRun.trigger.
enum BriefingTrigger {
  scheduled
  manual
}

// database-schema.md §briefing — BriefingRun.status. `partial` = one or more
// steps failed but the run composed something useful (never blank).
enum BriefingStatus {
  queued
  running
  partial
  complete
  failed
}

// database-schema.md §briefing — BriefingItem.kind. Advisory Green artifacts.
enum BriefingItemKind {
  opportunity
  tailored_resume
  draft
  prep
  gap
  note
  focus
  suggestion
}

// database-schema.md §briefing — BriefingItem.state. Items are proposed;
// nothing acts. A Yellow item is surfaced as proposed, never executed.
enum BriefingItemState {
  proposed
  approved
  edited
  skipped
  failed
}

// database-schema.md §cie — StrategyPlan.horizon. Five planning horizons ordered
// short → long (Prisma enum members cannot begin with a digit, so the '30d'…'5y'
// domain values map to d30…y5 here; the store translates at the boundary).
enum StrategyPlanHorizon {
  d30
  d90
  y1
  y3
  y5
}

// database-schema.md §cie — StrategyPlan.status. One ACTIVE plan per horizon;
// regeneration supersedes the prior with a stored diff + rationale.
enum StrategyPlanStatus {
  active
  superseded
}

// database-schema.md §cie — PlanAction.kind (normalized for adherence tracking).
enum PlanActionKind {
  skill
  project
  cert
  role
  network
  other
}

// database-schema.md §cie — PlanAction.status. Adherence lifecycle (M08 reads it).
enum PlanActionStatus {
  suggested
  in_progress
  done
  dropped
}


// ---------------- identity ----------------

model User {
  id               String           @id @default(uuid()) @db.Uuid
  email            String           @unique
  authProviderId   String           @unique @map("auth_provider_id")
  subscriptionTier SubscriptionTier @default(free) @map("subscription_tier")
  status           UserStatus       @default(active)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  settings       UserSettings?
  profile        Profile?
  auditLogs      AuditLog[]
  approvalTokens ApprovalToken[]
  memoryEvents   MemoryEvent[]
  graphNodes     GraphNode[]
  graphEdges     GraphEdge[]
  applications   Application[]
  briefingRuns   BriefingRun[]
  strategyPlans  StrategyPlan[]

  @@map("users")


}

model UserSettings {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Per action-type Green/Yellow/Red overrides; may only tighten the gate registry.
  autonomyDefaults Json  @map("autonomy_defaults")
  quietHours       Json? @map("quiet_hours")
  briefingSchedule Json? @map("briefing_schedule")
  sourcePrefs      Json  @map("source_prefs")
  dataUseOptins    Json  @map("data_use_optins")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_settings")
}

model Profile {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  headline    String?
  summary     String?
  targetRoles Json?   @map("target_roles")
  targetComp  Json?   @map("target_comp")
  locations   Json?
  remotePref  String? @map("remote_pref")
  goals       Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  experiences Experience[]
  projects    Project[]
  education   Education[]
  skillClaims SkillClaim[]
  derivedInsights DerivedInsight[]
  matchScores     MatchScore[]

  @@index([userId])
  @@map("profiles")

}



model Experience {
  id        String  @id @default(uuid()) @db.Uuid
  profileId String  @map("profile_id") @db.Uuid
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  company    String
  title      String
  start      DateTime? @db.Date
  end        DateTime? @db.Date
  bullets    Json?
  skills     String[]
  provenance Provenance
  version    Int        @default(1)
  /// pgvector embedding for memory retrieval (hnsw index added in migration SQL).
  embedding  Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([profileId])
  @@map("experiences")
}

model Project {
  id        String  @id @default(uuid()) @db.Uuid
  profileId String  @map("profile_id") @db.Uuid
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name        String
  description String?
  links       Json?
  skills      String[]
  provenance  Provenance
  embedding   Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([profileId])
  @@map("projects")
}

model Education {
  id        String  @id @default(uuid()) @db.Uuid
  profileId String  @map("profile_id") @db.Uuid
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  institution String
  credential  String?
  field       String?
  start       DateTime?  @db.Date
  end         DateTime?  @db.Date
  provenance  Provenance

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([profileId])
  @@map("education")
}

model SkillClaim {
  id        String  @id @default(uuid()) @db.Uuid
  profileId String  @map("profile_id") @db.Uuid
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  skill        String
  level        SkillLevel
  /// refs into experience/project ids evidencing this skill
  evidenceRefs Json?      @map("evidence_refs")
  provenance   Provenance
  embedding    Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([profileId])
  @@map("skill_claims")
}

// ---------------- opportunity (global, not user-owned) ----------------

model Opportunity {
  id        String         @id @default(uuid()) @db.Uuid
  sourceKey String         @map("source_key")
  source    SourceRegistry @relation(fields: [sourceKey], references: [key])
  sourceRef String         @map("source_ref")

  company            String
  role               String
  comp               Json?
  location           String?
  remote             Boolean?
  requirementsParsed Json?    @map("requirements_parsed")
  /// UNTRUSTED ingested payload — sanitized by packages/connectors before persist.
  rawPayload         Json     @map("raw_payload")
  dedupKey           String   @map("dedup_key")
  ingestedAt         DateTime @map("ingested_at")
  embedding          Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  matchScores MatchScore[]

  @@unique([sourceKey, sourceRef])
  @@index([dedupKey])
  @@map("opportunities")
}


/// A discovery-time (profile, opportunity) MatchScore (database-schema.md §opportunity).
/// The scorer's honest, grounded output: `overall` (0–100) + `subscores` (jsonb) +
/// a plain-language `explanation` (never a bare number) + `evidenceRefs` (jsonb: the
/// real profile fact ids the explanation grounds itself in) + a `modelVersion` stamp.
///
/// UNIQUE `(profile_id, opportunity_id, model_version)` — 1:many OVER model versions
/// (each version a reproducible row for audit); the app reads the LATEST version for
/// display. Per-user by construction: `profile_id` binds the score to one user's
/// profile, so users A and B get DIFFERENT MatchScore rows for the SAME opportunity.
model MatchScore {
  id            String      @id @default(uuid()) @db.Uuid
  profileId     String      @map("profile_id") @db.Uuid
  profile       Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  opportunityId String      @map("opportunity_id") @db.Uuid
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  overall      Int
  subscores    Json
  explanation  String
  evidenceRefs Json    @map("evidence_refs")
  modelVersion String  @map("model_version")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([profileId, opportunityId, modelVersion])
  @@index([opportunityId])
  @@map("match_scores")
}

// ---------------- application pipeline (per-user CRM — database-schema.md §application) ----------------

/// A per-user Application: the CRM record binding ONE user to ONE opportunity as
/// they move it through the fixed status pipeline (saved…closed). PER-USER scoped —
/// `(user_id, opportunity_id)` is UNIQUE, so a user tracks a given opportunity once;
/// users A and B keep independent applications for the SAME global opportunity.
///
/// `resume_variant_id` optionally links a tailored resume variant. It is a plain
/// string (no FK) because resume variants are not yet a persisted Prisma table
/// (M03 stores them in-memory) — the column is forward-compatible for when they are.
///
/// `applied_at` is set ONLY on the human-in-the-loop transition to `applied`
/// (the explicit "I submitted this" user action); it is never written by an agent.
model Application {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  opportunityId   String  @map("opportunity_id") @db.Uuid
  resumeVariantId String? @map("resume_variant_id")

  status    ApplicationStatus @default(saved)
  notes     String?
  followUpAt DateTime?        @map("follow_up_at")
  /// Timestamp of the explicit user submit (the applied transition); null until then.
  appliedAt DateTime?         @map("applied_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  timeline  ApplicationTimelineEntry[]
  followUps ApplicationFollowUp[]

  @@unique([userId, opportunityId])
  @@index([userId, status])
  @@map("applications")
}

/// APPEND-ONLY status-change history for an Application (database-schema.md
/// §application). One row per meaningful transition, recording where it came from
/// (`from_status`, null on create), where it went (`to_status`), WHO drove it
/// (`actor`), and an optional note. Rows are removed solely by the parent cascade.
model ApplicationTimelineEntry {
  id            String      @id @default(uuid()) @db.Uuid
  applicationId String      @map("application_id") @db.Uuid
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  fromStatus ApplicationStatus? @map("from_status")
  toStatus   ApplicationStatus  @map("to_status")
  actor      AuditActor
  note       String?
  at         DateTime           @default(now())

  @@index([applicationId, at])
  @@map("application_timeline")
}

/// An INTERNAL follow-up reminder for an Application (Green; no external send ever
/// leaves the system — architecture.md autonomy tiers). Just a due date + note the
/// user sees inside the app; `done` flips when acknowledged.
model ApplicationFollowUp {
  id            String      @id @default(uuid()) @db.Uuid
  applicationId String      @map("application_id") @db.Uuid
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  dueAt DateTime @map("due_at")
  note  String?
  done  Boolean  @default(false)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([applicationId, dueAt])
  @@map("application_follow_ups")
}

// ---------------- connectors ----------------



model SourceRegistry {
  id      String     @id @default(uuid()) @db.Uuid
  key     String     @unique
  type    SourceType
  enabled Boolean    @default(false)
  /// Exact hostnames the guarded fetch layer may contact for this source.
  hosts      Json
  ratePolicy Json?   @map("rate_policy")
  mapping    Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  opportunities Opportunity[]

  @@map("source_registry")
}

// ---------------- audit / security ----------------

/// Append-only: no application code path updates or deletes rows; removal happens
/// only via account hard-delete cascade (database-schema.md §4).
model AuditLog {
  id     String     @id @default(uuid()) @db.Uuid
  userId String     @map("user_id") @db.Uuid
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor  AuditActor
  action String
  target String?
  reason String
  modelVersion String? @map("model_version")
  traceId      String? @map("trace_id")
  at           DateTime @default(now())

  @@index([userId, at])
  @@map("audit_log")
}

/// Binds a Yellow action to one user + one exact approved payload; single-use.
model ApprovalToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  payloadHash String    @map("payload_hash")
  expiresAt   DateTime  @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([userId, expiresAt])
  @@map("approval_tokens")
}

// ---------------- memory (M02 — database-schema.md §memory) ----------------

/// Episodic tier. APPEND-ONLY: no application code path updates or deletes rows;
/// removal happens ONLY via account hard-delete cascade (database-schema.md §4,
/// same immutability contract as AuditLog). Written on profile import/edit and on
/// every Twin action / user decision. `payload` is opaque JSON; `rationale` is the
/// why-it-happened note the semantic tier distills from.
model MemoryEvent {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type         MemoryEventType
  payload      Json
  rationale    String?
  autonomyTier String?         @map("autonomy_tier")
  occurredAt   DateTime        @default(now()) @map("occurred_at")

  @@index([userId, occurredAt])
  @@map("memory_events")
}

/// Semantic tier. REGENERABLE + NON-AUTHORITATIVE: distilled from profile +
/// episodic memory; safe to drop and rebuild (regenerate()). Never a source of
/// truth — carries `sourceRefs` back to the authoritative rows/events it summarized,
/// a `freshnessAt` staleness marker, and the `modelVersion` that produced it.
model DerivedInsight {
  id        String  @id @default(uuid()) @db.Uuid
  profileId String  @map("profile_id") @db.Uuid
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  statement    String
  sourceRefs   Json     @map("source_refs")
  freshnessAt  DateTime @map("freshness_at")
  modelVersion String?  @map("model_version")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([profileId])
  @@map("derived_insights")
}

// ---------------- CIE — Career Knowledge Graph (database-schema.md §cie) ----------------

/// GraphNode.kind — the fixed enum from database-schema.md §cie.
enum GraphNodeKind {
  person
  company
  recruiter
  interview
  resume
  project
  certification
  skill
  industry
  application
  outcome
  learning_resource
  opportunity
  goal
}

/// GraphEdge.type — the typed relationship enum from database-schema.md §cie.
enum GraphEdgeType {
  worked_at
  requires_skill
  has_skill
  demonstrates
  interviewed_with
  led_to_outcome
  builds_toward_goal
  taught_by
  competes_with
  reports_to
  located_in
  targets
  evidenced_by
  studied_at
}

/// A Career Knowledge Graph node (database-schema.md §cie). `key` is the per-user
/// natural dedupe key (e.g. `company:acme corp`) that makes upsert-from-profile
/// idempotent. `refId` points back at the owning domain row when one exists.
/// `embedding` is the node's pgvector vector for similarity search.
model GraphNode {
  id     String        @id @default(uuid()) @db.Uuid
  userId String        @map("user_id") @db.Uuid
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  kind      GraphNodeKind
  /// Natural dedupe key: `(userId, kind, key)` is unique per user.
  key       String
  /// Points back at the owning domain row (e.g. experience id, project id).
  refId     String? @map("ref_id")
  label     String
  attrs     Json    @default("{}")
  /// pgvector embedding for similarity search (hnsw index added in migration SQL).
  embedding Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  edgesFrom GraphEdge[] @relation("from_node")
  edgesTo   GraphEdge[] @relation("to_node")

  @@unique([userId, kind, key])
  @@index([userId, kind])
  @@map("graph_nodes")
}

// ---------------- briefing (M05 Stage-5 Step-5 — database-schema.md §briefing) ----------------

/// The audit backbone for a composed briefing. Records per-step status + cost +
/// trace_id in `steps` (jsonb) so a partial run (one step failed) is a first-class
/// outcome — the run is NEVER blank. Idempotent + resilient: a failing step is
/// flagged + retryable while the whole composes what it could. PER-USER by
/// construction (`user_id` cascade).
model BriefingRun {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  trigger    BriefingTrigger
  status     BriefingStatus  @default(queued)
  /// Inputs that shaped this run (e.g. filters, top-N). Opaque JSON.
  inputs     Json            @default("{}")
  /// Per-step status/cost/trace_id records — the audit trail on the run itself.
  steps      Json            @default("[]")
  costTotal  Float           @default(0) @map("cost_total")
  startedAt  DateTime        @default(now()) @map("started_at")
  finishedAt DateTime?       @map("finished_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items BriefingItem[]

  @@index([userId, startedAt(sort: Desc)])
  @@map("briefing_runs")
}

/// One advisory Green artifact composed into a briefing. `kind` is what the item
/// represents (opportunity | gap | focus | suggestion | …). `state` is `proposed`
/// — nothing acts. A Yellow item is surfaced as proposed, never executed.
model BriefingItem {
  id            String       @id @default(uuid()) @db.Uuid
  briefingRunId String       @map("briefing_run_id") @db.Uuid
  run           BriefingRun  @relation(fields: [briefingRunId], references: [id], onDelete: Cascade)

  kind          BriefingItemKind
  /// Optional ref to the source domain row (opportunity id, application id, etc.).
  refId         String?           @map("ref_id")
  /// The autonomy tier this item WOULD require if acted on (green|yellow|red).
  autonomyTier  String            @default("green") @map("autonomy_tier")
  state         BriefingItemState @default(proposed)
  /// The composed content the UI renders (title/summary/evidence/etc.).
  payload       Json              @default("{}")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([briefingRunId])
  @@map("briefing_items")
}

// ---------------- CIE — Strategy Plans (M06 — database-schema.md §cie) ----------------

/// A persisted, per-user, per-horizon StrategyPlan (database-schema.md §cie). The
/// Strategy-Planner's grounded output for ONE horizon (30d/90d/1y/3y/5y). Exactly
/// ONE plan per (user, horizon) is `active` at a time — enforced by a PARTIAL
/// unique index `(user_id, horizon) WHERE status='active'` in the migration SQL.
///
/// Adaptive regeneration SUPERSEDES the prior active plan: the old row flips to
/// `superseded` and points forward via `supersededById`; the new row stores the
/// human-readable `diffSummary` ("moved X earlier because…") + `rationale` that
/// explain WHY it changed. Sub-threshold changes never write a row (anti-thrash).
model StrategyPlan {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  horizon      StrategyPlanHorizon
  status       StrategyPlanStatus  @default(active)
  /// The plan's own narrative summary / theme for this horizon.
  summary      String
  /// The grounded goal ids this plan ladders toward (jsonb array of strings).
  goalRefs     Json                @default("[]") @map("goal_refs")
  /// Human-readable diff vs the plan it superseded ("moved X earlier because…").
  /// Null on a first-generation plan (nothing to diff against).
  diffSummary  String?             @map("diff_summary")
  /// Why this (re)generation happened — the §4A material-change rationale.
  rationale    String?
  modelVersion String              @map("model_version")

  /// Supersession chain: the superseded row points forward to its replacement.
  supersededById String?        @map("superseded_by_id") @db.Uuid
  supersededBy   StrategyPlan?  @relation("supersession", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes     StrategyPlan[] @relation("supersession")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  actions PlanAction[]

  @@index([userId, horizon, status])
  @@map("strategy_plans")
}

/// One laddered, justified action inside a StrategyPlan (database-schema.md §cie).
/// `orderIndex` is the plan's sequence (today's move = the top action of the
/// active 30-day plan). `status`/`progress` track adherence (user-updated via
/// PATCH). `evidenceRefs` grounds the action in real goals/graph/gaps — the
/// deterministic guardrail (packages/cie/planner) forbids ungrounded actions.
model PlanAction {
  id     String       @id @default(uuid()) @db.Uuid
  planId String       @map("plan_id") @db.Uuid
  plan   StrategyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  /// Stable per-plan action key (mirrors the planner's action ids) for diffing.
  actionKey    String           @map("action_key")
  kind         PlanActionKind   @default(other)
  title        String
  rationale    String
  orderIndex   Int              @map("order_index")
  status       PlanActionStatus @default(suggested)
  /// Adherence progress 0–100 (user-updated). Defaults to 0.
  progress     Int              @default(0)
  evidenceRefs Json             @default("[]") @map("evidence_refs")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([planId, orderIndex])
  @@map("plan_actions")
}

/// A typed, directed relationship between two GraphNodes. Traversal is
/// BIDIRECTIONAL — an edge is followable from either endpoint — so
/// `(userId, from, type)` and `(userId, to, type)` are both indexed.
model GraphEdge {
  id     String       @id @default(uuid()) @db.Uuid
  userId String       @map("user_id") @db.Uuid
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  fromNodeId String       @map("from_node_id") @db.Uuid
  fromNode   GraphNode    @relation("from_node", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNodeId   String       @map("to_node_id") @db.Uuid
  toNode     GraphNode    @relation("to_node", fields: [toNodeId], references: [id], onDelete: Cascade)
  type       GraphEdgeType
  weight     Float        @default(1)
  attrs      Json         @default("{}")
  provenance String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, fromNodeId, toNodeId, type])
  @@index([userId, fromNodeId, type])
  @@index([userId, toNodeId, type])
  @@map("graph_edges")
}
