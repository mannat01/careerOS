# Validated by packages/config env schema. Never read process.env elsewhere.
DATABASE_URL=postgresql://localhost:5432/careeros
REDIS_URL=redis://localhost:6379
S3_BUCKET=careeros-artifacts
AUTH_PROVIDER=clerk            # clerk | workos (M01 decision)
LLM_PRIMARY_PROVIDER=anthropic # ADR-001: single vendor, two tiers
LLM_CHEAP_MODEL=               # default: claude-3-5-haiku-latest
LLM_FRONTIER_MODEL=            # default: claude-sonnet-4-5
ANTHROPIC_API_KEY=
APPROVAL_TOKEN_SECRET=         # >=32 chars; signs capability-gate ApprovalTokens
OTEL_EXPORTER_OTLP_ENDPOINT=
